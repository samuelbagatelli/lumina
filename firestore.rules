rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && incoming().keys().hasAll(['email', 'createdAt'])
        && incoming().email is string
        && incoming().email.size() <= 255
        && incoming().createdAt is string; // Using ISO string for consistency
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
      
      match /collections/{collectionId} {
        function isValidCollection(data) {
          return data.name is string && data.name.size() <= 100
            && data.userId == request.auth.uid
            && (data.parentId == null || data.parentId is string);
        }

        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCollection(incoming());
        allow update: if isOwner(userId) && isValidCollection(incoming());
        allow delete: if isOwner(userId);
      }

      match /books/{bookId} {
        function isValidBook(data) {
          return data.title is string && data.title.size() <= 200
            && data.author is string && data.author.size() <= 200
            && data.status in ['Want to Read', 'Reading', 'Completed']
            && data.progress is number && data.progress >= 0 && data.progress <= 100
            && data.userId == request.auth.uid
            && data.addedAt is string;
        }

        // List queries must be filtered by the rule to be secure
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidBook(incoming())
          && incoming().keys().hasAll(['title', 'author', 'pages', 'status', 'progress', 'addedAt', 'userId'])
          && (incoming().pages is number && incoming().pages > 0);
          
        allow update: if isOwner(userId)
          && isValidBook(incoming())
          && (
            // Action: Update Progress
            (incoming().diff(existing()).affectedKeys().hasOnly(['readPages', 'progress', 'status', 'completedAt'])) ||
            // Action: Update Status
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'completedAt'])) ||
            // Action: Edit Details
            (incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'rating', 'genre', 'synopsis', 'collectionId']))
          );
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
